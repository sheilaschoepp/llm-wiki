{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(brew install:*)",
      "Bash(brew reinstall:*)",
      "Bash(brew upgrade:*)",
      "Bash(brew uninstall:*)",
      "Bash(pip install:*)",
      "Bash(pip uninstall:*)",
      "Bash(pip3 install:*)",
      "Bash(pip3 uninstall:*)",
      "Bash(python -m pip install:*)",
      "Bash(python -m pip uninstall:*)",
      "Bash(python3 -m pip install:*)",
      "Bash(python3 -m pip uninstall:*)",
      "Bash(uv pip install:*)",
      "Bash(uv pip uninstall:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(pipx install:*)",
      "Bash(pipx uninstall:*)",
      "Bash(conda install:*)",
      "Bash(conda update:*)",
      "Bash(conda remove:*)",
      "Bash(mamba install:*)",
      "Bash(mamba update:*)",
      "Bash(mamba remove:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm update:*)",
      "Bash(npm up:*)",
      "Bash(npm upgrade:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm un:*)",
      "Bash(npm remove:*)",
      "Bash(npm rm:*)",
      "Bash(npm r:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(trash:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git tag -d:*)",
      "Bash(git tag --delete:*)",
      "Bash(git stash clear:*)",
      "Bash(git stash drop:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout --force:*)",
      "Bash(git checkout -f:*)",
      "Bash(git checkout .:*)",
      "Bash(git restore .:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/context_usage_footer.py\""
          }
        ]
      }
    ]
  }
}